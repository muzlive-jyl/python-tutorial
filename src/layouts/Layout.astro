---
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  currentSlug?: string;
}

const { title, currentSlug } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="ASS-to-LRC 프로젝트로 배우는 Python 튜토리얼" />
    <title>{title} | Python 튜토리얼</title>
  </head>
  <body>
    <button class="menu-toggle" id="menuToggle" aria-label="메뉴 열기">
      ☰
    </button>
    <div class="layout">
      <aside class="sidebar" id="sidebar">
        <Sidebar currentSlug={currentSlug} />
      </aside>
      <main class="content">
        <slot />
      </main>
    </div>

    <script>
      const toggle = document.getElementById('menuToggle')!;
      const sidebar = document.getElementById('sidebar')!;
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('open');
      });
      document.addEventListener('click', (e) => {
        if (
          window.innerWidth <= 768 &&
          !sidebar.contains(e.target as Node) &&
          !toggle.contains(e.target as Node)
        ) {
          sidebar.classList.remove('open');
        }
      });
    </script>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --sidebar-width: 280px;
        --color-bg: #ffffff;
        --color-text: #1a1a2e;
        --color-sidebar-bg: #f8f9fa;
        --color-border: #e2e8f0;
        --color-primary: #3b82f6;
        --color-primary-light: #eff6ff;
        --color-code-bg: #1e293b;
        --color-code-text: #e2e8f0;
        --color-tip-bg: #ecfdf5;
        --color-tip-border: #10b981;
        --color-warning-bg: #fffbeb;
        --color-warning-border: #f59e0b;
      }

      html {
        font-family:
          'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          sans-serif;
        font-size: 16px;
        line-height: 1.7;
        color: var(--color-text);
        background: var(--color-bg);
      }

      .layout {
        display: flex;
        min-height: 100vh;
      }

      .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        width: var(--sidebar-width);
        height: 100vh;
        overflow-y: auto;
        background: var(--color-sidebar-bg);
        border-right: 1px solid var(--color-border);
        padding: 2rem 0;
        z-index: 100;
      }

      .content {
        margin-left: var(--sidebar-width);
        flex: 1;
        padding: 3rem 4rem;
        max-width: 800px;
      }

      .menu-toggle {
        display: none;
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 200;
        background: var(--color-primary);
        color: white;
        border: none;
        border-radius: 8px;
        width: 44px;
        height: 44px;
        font-size: 1.25rem;
        cursor: pointer;
      }

      @media (max-width: 768px) {
        .sidebar {
          transform: translateX(-100%);
          transition: transform 0.3s ease;
        }
        .sidebar.open {
          transform: translateX(0);
        }
        .content {
          margin-left: 0;
          padding: 2rem 1.5rem;
          padding-top: 4rem;
        }
        .menu-toggle {
          display: block;
        }
      }

      :global(h1) {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.3;
      }

      :global(h2) {
        font-size: 1.5rem;
        font-weight: 600;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--color-border);
      }

      :global(h3) {
        font-size: 1.25rem;
        font-weight: 600;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
      }

      :global(p) {
        margin-bottom: 1rem;
      }

      :global(ul),
      :global(ol) {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
      }

      :global(li) {
        margin-bottom: 0.5rem;
      }

      :global(code) {
        background: var(--color-sidebar-bg);
        padding: 0.15em 0.4em;
        border-radius: 4px;
        font-size: 0.9em;
        font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      }

      :global(pre) {
        background: var(--color-code-bg);
        color: var(--color-code-text);
        padding: 1rem 1.25rem;
        border-radius: 8px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
        position: relative;
      }

      :global(pre code) {
        background: none;
        padding: 0;
        font-size: 0.875rem;
        color: inherit;
      }

      :global(strong) {
        font-weight: 600;
      }

      :global(hr) {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2rem 0;
      }

      :global(blockquote) {
        border-left: 4px solid var(--color-primary);
        padding: 0.75rem 1rem;
        margin: 1rem 0 1.5rem;
        background: var(--color-primary-light);
        border-radius: 0 8px 8px 0;
      }

      :global(blockquote p) {
        margin-bottom: 0;
      }

      :global(.chapter-nav) {
        display: flex;
        justify-content: space-between;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
        gap: 1rem;
      }

      :global(.chapter-nav a) {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        background: var(--color-primary-light);
        color: var(--color-primary);
        text-decoration: none;
        border-radius: 8px;
        font-weight: 500;
        transition: background 0.2s;
      }

      :global(.chapter-nav a:hover) {
        background: var(--color-primary);
        color: white;
      }

      :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5rem;
      }

      :global(th),
      :global(td) {
        border: 1px solid var(--color-border);
        padding: 0.5rem 0.75rem;
        text-align: left;
      }

      :global(th) {
        background: var(--color-sidebar-bg);
        font-weight: 600;
      }
    </style>
  </body>
</html>
