---
interface Props {
  command: string;
  description?: string;
}

const { command, description } = Astro.props;
---

<div class="command-block">
  {description && <div class="command-desc">{description}</div>}
  <div class="command-line">
    <span class="prompt">$</span>
    <code>{command}</code>
    <button class="copy-btn" data-command={command} aria-label="복사">
      <span class="copy-icon">📋</span>
      <span class="copied-icon" style="display:none">✅</span>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const command = (btn as HTMLElement).dataset.command!;
      await navigator.clipboard.writeText(command);
      const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
      const copiedIcon = btn.querySelector('.copied-icon') as HTMLElement;
      copyIcon.style.display = 'none';
      copiedIcon.style.display = 'inline';
      setTimeout(() => {
        copyIcon.style.display = 'inline';
        copiedIcon.style.display = 'none';
      }, 2000);
    });
  });
</script>

<style>
  .command-block {
    background: var(--color-code-bg, #1e293b);
    border-radius: 8px;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .command-desc {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    color: #94a3b8;
    border-bottom: 1px solid #334155;
  }

  .command-line {
    display: flex;
    align-items: center;
    padding: 0.75rem 1rem;
    gap: 0.5rem;
  }

  .prompt {
    color: #10b981;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-weight: 700;
    user-select: none;
  }

  code {
    color: #e2e8f0;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.9rem;
    flex: 1;
    background: none !important;
    padding: 0 !important;
  }

  .copy-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: background 0.2s;
    font-size: 0.9rem;
    line-height: 1;
  }

  .copy-btn:hover {
    background: #334155;
  }
</style>
